{
  "schema": "game-result.v1",
  "description": "Recommended Arrow/Parquet physical schema for completed Quantik head-to-head games.",
  "storage": "parquet",
  "columns": [
    { "name": "schema", "type": "utf8", "required": true },
    { "name": "contract_version", "type": "utf8", "required": true },
    { "name": "game_id", "type": "utf8", "required": true },
    { "name": "started_at", "type": "timestamp or utf8", "required": true },
    { "name": "p0_engine_kind", "type": "utf8", "required": true },
    { "name": "p0_engine_version", "type": "utf8", "required": true },
    { "name": "p0_engine_checkpoint", "type": "utf8", "required": false },
    { "name": "p1_engine_kind", "type": "utf8", "required": true },
    { "name": "p1_engine_version", "type": "utf8", "required": true },
    { "name": "p1_engine_checkpoint", "type": "utf8", "required": false },
    { "name": "opening_book_id", "type": "utf8", "required": false },
    { "name": "initial_position_key", "type": "fixed_size_binary[16] or utf8", "required": true },
    { "name": "winner", "type": "int8", "required": true, "allowed": [0, 1] },
    { "name": "plies", "type": "uint16", "required": true },
    { "name": "terminal_reason", "type": "utf8", "required": true },
    { "name": "seed", "type": "uint64", "required": false },
    { "name": "time_budget_ms_per_move", "type": "uint32", "required": false },
    { "name": "node_budget_per_move", "type": "uint64", "required": false },
    { "name": "move_action_indices", "type": "list<uint8>", "required": true },
    { "name": "position_keys", "type": "list<fixed_size_binary[16]>", "required": false },
    { "name": "hardware", "type": "utf8", "required": false },
    { "name": "run_id", "type": "utf8", "required": false }
  ],
  "notes": [
    "game-result.v1 is for completed games, not root search observations.",
    "Current Quantik contracts encode no draw outcome.",
    "Use this data for H2H stats and Elo proxy estimation."
  ]
}
